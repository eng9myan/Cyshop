# --- Public domain (single domain, Caddy reverse-proxies /api/* to backend) ---
PUBLIC_DOMAIN=cyshop.cy-com.com
CADDY_EMAIL=admin@cy-com.com

# --- Django ---
DJANGO_SECRET_KEY=replace-with-output-of: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=cyshop.cy-com.com,localhost,127.0.0.1,cyshop-backend
DJANGO_CSRF_TRUSTED_ORIGINS=https://cyshop.cy-com.com
DJANGO_CORS_ALLOWED_ORIGINS=https://cyshop.cy-com.com

# --- Database (Postgres) ---
DB_NAME=cyshop_db
DB_USER=cyshop_admin
DB_PASSWORD=change-me-strong-password

# --- Frontend (Next.js) ---
# Leave empty for same-origin via Caddy. Only set if frontend and backend live on different hostnames.
NEXT_PUBLIC_API_URL=
